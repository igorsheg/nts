{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "margin": 2
  },
  "block_quote": {
    "indent": 1,
    "indent_token": "│ ",
    "color": "7"
  },
  "paragraph": {},
  "list": {
    "level_indent": 4
  },
  "heading": {
    "block_suffix": "\n",
    "bold": true
  },
  "h1": {
    "prefix": "# ",
    "bold": true,
    "color": "4"
  },
  "h2": {
    "prefix": "## ",
    "bold": true,
    "color": "4"
  },
  "h3": {
    "prefix": "### ",
    "bold": true
  },
  "h4": {
    "prefix": "#### ",
    "bold": true
  },
  "h5": {
    "prefix": "##### ",
    "bold": true
  },
  "h6": {
    "prefix": "###### ",
    "bold": true
  },
  "text": {},
  "strikethrough": {
    "crossed_out": true
  },
  "emph": {
    "italic": true
  },
  "strong": {
    "bold": true
  },
  "hr": {
    "format": "\n────────────────────\n",
    "color": "8"
  },
  "item": {
    "block_prefix": "• "
  },
  "enumeration": {
    "block_prefix": ". "
  },
  "task": {
    "ticked": "[✓] ",
    "unticked": "[ ] "
  },
  "link": {
    "color": "6",
    "underline": true
  },
  "link_text": {
    "color": "6",
    "bold": true
  },
  "image": {
    "color": "6"
  },
  "image_text": {
    "color": "6"
  },
  "code": {
    "color": "3"
  },
  "code_block": {
    "color": "7",
    "margin": 4,
    "chroma": {
      "theme": "native"
    }
  },
  "table": {
    "center_separator": "┼",
    "column_separator": "│",
    "row_separator": "─"
  },
  "definition_list": {},
  "definition_term": {
    "bold": true
  },
  "definition_description": {
    "block_prefix": "\n"
  },
  "html_block": {},
  "html_span": {}
}
